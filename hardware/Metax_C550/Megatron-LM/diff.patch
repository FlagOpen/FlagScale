+        input_ids = torch.full((batch_size, seq_length), 100, dtype=torch.long, device=self.device)
+
+        # Define special token IDs
+        vision_token_id = 50
+        audio_token_id = 51
+        video_token_id = 52
+
+        # Add special tokens at different positions in each sequence
