+@router.post("/tokenize")
+async def tokenize(request: TokenizeRequest, raw_request: Request):
+    tok = tokenization(raw_request)
+    if tok is None:
+        return JSONResponse(content="No available TX cards", status_code=500)
+
+    generator = await tok.create_tokenize(request)
+    if isinstance(generator, ErrorResponse):
+        result = JSONResponse(content=generator.model_dump(),
+                            status_code=generator.code)
+        tok.is_busy = False
+        return result
+    elif isinstance(generator, TokenizeResponse):
+        result = JSONResponse(content=generator.model_dump())
+
+        tok.is_busy = False
+        return result
+
+    assert_never(generator)
+
