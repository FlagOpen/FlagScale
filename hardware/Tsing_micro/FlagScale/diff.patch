+'''
+Author: fuchong fuchong@dev.com
+Date: 2025-02-03 16:43:46
+LastEditors: fuchong fuchong@dev.com
+LastEditTime: 2025-02-07 10:44:13
+FilePath: examples/tx8_utils/ts_probe_api.py
+'''
+
+
+
+DUMPER=None
+
+def init_dumper(tsprobe_config, model, level='L1', dump_path='./dump', step=None):
+    from tsprobe.pytorch import PrecisionDebugger
+    global DUMPER
+    DUMPER = PrecisionDebugger(config_path=tsprobe_config,
+                                level = level,
+                                model = model,
+                                step=step,
+                                dump_path=dump_path)
+def _not_skip_dump(gradient_accumulation_steps, step):
+    skip = False
+    if gradient_accumulation_steps > 1:
+        if step % gradient_accumulation_steps == 1:   
+            skip = True   
+    else:
+        skip = True
+    return skip
+    
+def dumper_start(gradient_accumulation_steps, step):
+    DUMPER.start() if DUMPER and _not_skip_dump(gradient_accumulation_steps, step) else None
+    
+def dumper_end(gradient_accumulation_steps, step):
+    DUMPER.forward_backward_dump_end() if DUMPER and _not_skip_dump(gradient_accumulation_steps, step) else None
+
+def dumper_step(gradient_accumulation_steps, step):
+    DUMPER.step() if DUMPER and _not_skip_dump(gradient_accumulation_steps, step) else None
+
+def dumper_stop(gradient_accumulation_steps, step):
+    DUMPER.stop() if DUMPER and _not_skip_dump(gradient_accumulation_steps, step) else None
+
+def dumper_kong_step():
+    DUMPER.kong_step() if DUMPER  else None
+
+def dumper_stop_and_step(gradient_accumulation_steps, step):
+    if gradient_accumulation_steps > 1:
+        if step % gradient_accumulation_steps == 1:
+            dumper_stop(gradient_accumulation_steps, step)
+            dumper_step(gradient_accumulation_steps, step)
+        else:
+            dumper_kong_step()        
+    else:
+        dumper_stop(gradient_accumulation_steps, step)
+        dumper_step(gradient_accumulation_steps, step)     
+        
