+        f.write(f"cd {root_dir}\n")
+        f.write(f"\n")
+        f.write(f"export PYTHONPATH={tsing_examples_dir}:{tsing_examples_dir}/llama3_70B_finetune:{root_dir}:${{PYTHONPATH}}\n")
+        f.write(f"\n")
+        f.write(f'cmd="{cmd}"\n')
+        f.write(f"\n")
+        if with_test:
