+@router.post("/v1/chat/completions")
+async def create_chat_completion(request: ChatCompletionRequest,
+                                 raw_request: Request):
+    cha = chat(raw_request)
+    if cha is None:
+        return JSONResponse(content="No available TX cards", status_code=500)
+
+    chat_history(request, raw_request)
+
+    generator = await cha.create_chat_completion(
+        request, raw_request)
+
+    if isinstance(generator, ErrorResponse):
+        cha.is_busy = False
+        return JSONResponse(content=generator.model_dump(),
+                            status_code=generator.code)
+
+    elif isinstance(generator, ChatCompletionResponse):
+        cha.is_busy = False
+        return JSONResponse(content=generator.model_dump())
+
+    async def _generator(*args, **kwargs):
+        gen_txt = ""
+        async for data in generator:
+            if data.startswith("data:") and data[5:].find("{") != -1:
+                data_json = json.loads(data[5:])
+                choices = data_json.get("choices", None)
+                if choices is not None:
+                    token_txt = choices[0].get("delta", {}).get("content", "")
+                    gen_txt += token_txt
+
+            yield data
+
+        cha.is_busy = False
+        update_history(request, raw_request, gen_txt)
+
+    return StreamingResponse(content=_generator(), media_type="text/event-stream")
+
+
+@router.post("/v1/completions")
+async def create_completion(request: CompletionRequest, raw_request: Request):
+    comple = completion(raw_request)
+    if comple is None:
+        return JSONResponse(content="No available TX cards", status_code=500)
+
+    generator = await comple.create_completion(
+        request, raw_request)
+    if isinstance(generator, ErrorResponse):
+        comple.is_busy = False
+        return JSONResponse(content=generator.model_dump(),
+                            status_code=generator.code)
+    elif isinstance(generator, CompletionResponse):
+        comple.is_busy = False
+        return JSONResponse(content=generator.model_dump())
+
+    async def _generator(*args, **kwargs):
+        async for data in generator:
+            yield data
+        comple.is_busy = False
+
+    return StreamingResponse(content=_generator(), media_type="text/event-stream")
+
+
+@router.post("/v1/embeddings")
+async def create_embedding(request: EmbeddingRequest, raw_request: Request):
