+def parse_int_list_cn(s,tp_size):
+    try:
+        int_list_cn = []
+        card_num = ''.join(s.split())
+        parts = card_num.split(",")
+        for part in parts:
+            if '..' in part:
+                start,end = part.split('..')
+                for num in range(int(start), int(end)+1):
+                    int_list_cn.append(num)
+            else:
+                int_list_cn.append(int(part))
+        int_list_cn.sort()
+        if not all(0 <= num <= 31 for num in int_list_cn):
+            raise argparse.ArgumentTypeError("Card number must be a continuous integer from 0 to 31.")
+        for index in range(0, len(int_list_cn), tp_size):
+            if len(int_list_cn) != 1:
+                check_list = []
+                for i in range(index, index+tp_size):
+                    check_list.append(int_list_cn[i])
+                if sorted(check_list) != list(range(min(check_list), max(check_list) + 1)):
+                    raise argparse.ArgumentTypeError("Card number must be a continuous integer from 0 to 31.")
+            else:
+                check_str = int_list_cn[0]
+    except ValueError:
+        raise argparse.ArgumentTypeError("Card number must be a continuous integer from 0 to 31.")
+    return int_list_cn
