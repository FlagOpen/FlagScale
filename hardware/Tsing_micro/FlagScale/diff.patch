+def chat_history(request: ChatCompletionRequest, raw_request: Request):
+    user = request.user
+    print(f"/v1/chat/completions request, user: {user}")
+
+    if user is None:
+        return
+
+    messages = request.messages
+    for msg in messages:
+        msg['token_length'] = len(HISTORY_TOKEN_NUM_TOKENIZER.apply_chat_template([msg], tokenize=True, add_generation_prompt=True))
+    history = raw_request.app.state.user_history.get(user)
+
+    if history is None:
+        raw_request.app.state.user_history[user] = copy.deepcopy(messages)
+    else:
+        raw_request.app.state.user_history[user].extend(messages)
+        request.messages = copy.deepcopy(raw_request.app.state.user_history[user])
+
+
+def update_history(request: ChatCompletionRequest, raw_request: Request, assistant_gen_text: str):
+    user = request.user
+    if user is None:
+        return
+
+    assistant_response = {"role": "assistant", "content": assistant_gen_text}
+
+    assistant_response_len = len(HISTORY_TOKEN_NUM_TOKENIZER.apply_chat_template([assistant_response], tokenize=True, add_generation_prompt=True))
+    assistant_response['token_length'] = assistant_response_len
+
+    history = raw_request.app.state.user_history.get(user)
+    if history is not None:
+        raw_request.app.state.user_history[user].append(assistant_response)
+
+    #truncat the history
+    history_len = 0
+    truncated_history = []
+    for history_item in reversed(raw_request.app.state.user_history[user]):
+        history_len += history_item['token_length']
+        if history_len > (MAX_MODEL_LEN // 2):
+            break
+        else:
+            truncated_history.insert(0, history_item)
+
+    #truncat happens
+    if len(truncated_history) != len(raw_request.app.state.user_history[user]):
+        raw_request.app.state.user_history[user] = truncated_history
+
+
